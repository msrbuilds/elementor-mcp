<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.0/phpunit.xsd"
         bootstrap="pro/tests/bootstrap.php"
         colors="true"
         stopOnFailure="false"
         beStrictAboutOutputDuringTests="true"
         failOnEmptyTestSuite="false">

    <testsuites>
        <testsuite name="Security">
            <directory>pro/tests/unit/Security</directory>
        </testsuite>
        <testsuite name="Capabilities">
            <directory>pro/tests/unit/capabilities</directory>
        </testsuite>
        <testsuite name="Input">
            <directory>pro/tests/unit/input</directory>
        </testsuite>
        <testsuite name="Functional">
            <directory>pro/tests/unit/functional</directory>
        </testsuite>
        <testsuite name="Regression">
            <directory>pro/tests/unit/regression</directory>
        </testsuite>
        <testsuite name="Dispatcher">
            <directory>pro/tests/unit/dispatcher</directory>
        </testsuite>
        <testsuite name="Skills">
            <directory>pro/tests/unit/skills</directory>
        </testsuite>
        <testsuite name="Widgets">
            <directory>pro/tests/unit/widgets</directory>
        </testsuite>
        <testsuite name="Content">
            <directory>pro/tests/unit/content</directory>
        </testsuite>
        <testsuite name="Settings">
            <directory>pro/tests/unit/settings</directory>
        </testsuite>
        <testsuite name="Packages">
            <directory>pro/tests/unit/packages</directory>
        </testsuite>
        <testsuite name="Media">
            <directory>pro/tests/unit/media</directory>
        </testsuite>
        <testsuite name="Users">
            <directory>pro/tests/unit/users</directory>
        </testsuite>
        <testsuite name="Admin">
            <directory>pro/tests/unit/admin</directory>
        </testsuite>
        <testsuite name="Performance">
            <directory>pro/tests/unit/Performance</directory>
        </testsuite>
        <testsuite name="Filesystem">
            <directory>pro/tests/unit/Filesystem</directory>
        </testsuite>
        <testsuite name="Database">
            <directory>pro/tests/unit/Database</directory>
        </testsuite>
        <testsuite name="Bootstrap">
            <directory>pro/tests/unit/Bootstrap</directory>
        </testsuite>
        <testsuite name="AiChat">
            <directory>pro/tests/unit/AiChat</directory>
        </testsuite>
        <testsuite name="Modules">
            <directory>pro/tests/unit/Modules</directory>
        </testsuite>
        <testsuite name="Gutenberg">
            <directory>pro/tests/unit/Gutenberg</directory>
        </testsuite>
        <testsuite name="Themer">
            <directory>pro/tests/unit/Themer</directory>
        </testsuite>
        <testsuite name="Seo">
            <directory>pro/tests/unit/seo</directory>
        </testsuite>
        <testsuite name="Snapshot">
            <directory>pro/tests/unit/snapshot</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory suffix=".php">includes</directory>
            <directory suffix=".php">pro/includes</directory>
        </include>
        <exclude>
            <directory>pro/tests</directory>
            <directory>vendor</directory>
        </exclude>
    </source>

</phpunit>
